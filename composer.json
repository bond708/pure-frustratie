{
    "name": "drupal/pure-frustratie",
    "description": "Drupal 11 website voor pure-frustratie.nl",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "repositories": {
        "drupal": {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    },
    "require": {
        "composer/installers": "^2.3",
        "drupal/admin_toolbar": "^3.5",
        "drupal/core-composer-scaffold": "^11.3",
        "drupal/core-project-message": "^11.3",
        "drupal/core-recommended": "^11.3",
        "drupal/core-vendor-hardening": "^11.3",
        "drupal/easy_breadcrumb": "^2.0",
        "drupal/field_group": "^4.0",
        "drupal/gin": "^5.0",
        "drupal/gin_login": "^2.1",
        "drupal/gin_toolbar": "^3.0",
        "drupal/google_tag": "^2.0",
        "drupal/honeypot": "^2.2",
        "drupal/linkit": "^7.0",
        "drupal/media_file_delete": "^1.3",
        "drupal/menu_link_attributes": "^1.6",
        "drupal/metatag": "^2.2",
        "drupal/pathauto": "^1.14",
        "drupal/redirect": "^1.12",
        "drupal/scheduler": "^2.2",
        "drupal/search_api": "^1.40",
        "drupal/simple_sitemap": "^4.2",
        "drupal/svg_image": "^3.2",
        "drupal/token": "^1.17",
        "drupal/webform": "^6.3.0-beta8",
        "drush/drush": "^13.7"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "drupal/core-vendor-hardening": true,
            "php-http/discovery": true
        },
        "bin-dir": "vendor/bin",
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3"
        }
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            },
            "file-mapping": {
                "[web-root]/sites/default/default.settings.php": {
                    "append": "assets/append-default.settings.php.txt"
                },
                "[web-root]/example.gitignore": false
            }
        },
        "installer-paths": {
            "web/core": ["type:drupal-core"],
            "web/libraries/{$name}": ["type:drupal-library"],
            "web/modules/contrib/{$name}": ["type:drupal-module"],
            "web/profiles/contrib/{$name}": ["type:drupal-profile"],
            "web/themes/contrib/{$name}": ["type:drupal-theme"],
            "./drush/Commands/contrib/{$name}": ["type:drupal-drush"],
            "web/modules/custom/{$name}": ["type:drupal-custom-module"],
            "web/profiles/custom/{$name}": ["type:drupal-custom-profile"],
            "web/themes/custom/{$name}": ["type:drupal-custom-theme"]
        },
        "drupal-core-project-message": {
            "include-keys": ["homepage", "support"],
            "post-create-project-cmd-message": [
                "Volgende stappen:",
                "  * Lees de gebruikershandleiding: https://www.drupal.org/docs/user_guide/en/index.html"
            ]
        }
    }
}
