{
  "name": "frustratie",
  "version": "1.0.0",
  "description": "Custom Drupal theme voor pure-frustratie.nl",
  "private": true,
  "scripts": {
    "build": "sass sass/main.scss css/main.css --style=compressed --no-source-map",
    "dev": "sass sass/main.scss css/main.css --style=expanded --source-map",
    "watch": "sass --watch sass/main.scss:css/main.css --style=expanded --source-map"
  },
  "devDependencies": {
    "sass": "^1.86.0"
  },
  "volta": {
    "node": "20.20.0",
    "npm": "10.8.2"
  }
}
